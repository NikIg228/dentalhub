                    { supplier: 'ТОО "Корея-Дент"', city: 'Астана', price: '11800 ₸', stock: 95, exp: '2027-04-20', markup: '25%', date: '2025-05-28', discount: '8%', priceDiscount: '10856 ₸', mult: '3' },
                    { supplier: 'ТОО "МедИмпорт КЗ"', city: 'Шымкент', price: '13200 ₸', stock: 60, exp: '2027-08-10', markup: '30%', date: '2025-05-29', discount: '12%', priceDiscount: '11616 ₸', mult: '1' }
                ];
            } else if (productId === '6') { // Карпульные иглы C-K Ject
                sampleData = [
                    { supplier: 'ТОО "Корея-Дент"', city: 'Астана', price: '11200 ₸', stock: 110, exp: '2027-05-15', markup: '22%', date: '2025-05-27', discount: '10%', priceDiscount: '10080 ₸', mult: '3' },
                    { supplier: 'ТОО "ДентТехно"', city: 'Алматы', price: '12000 ₸', stock: 85, exp: '2027-07-20', markup: '25%', date: '2025-05-28', discount: '12%', priceDiscount: '10560 ₸', mult: '2' },
                    { supplier: 'ТОО "МедИмпорт КЗ"', city: 'Шымкент', price: '11800 ₸', stock: 70, exp: '2027-06-05', markup: '28%', date: '2025-05-29', discount: '8%', priceDiscount: '10856 ₸', mult: '4' }
                ];
            } else if (productId === '7') { // Импланты Mega'gen
                sampleData = [
                    { supplier: 'ТОО "Имплант Центр КЗ"', city: 'Алматы', price: '45000 ₸', stock: 25, exp: '2030-12-31', markup: '35%', date: '2025-05-28', discount: '5%', priceDiscount: '42750 ₸', mult: '1' },
                    { supplier: 'ТОО "Корея Имплант"', city: 'Астана', price: '48500 ₸', stock: 18, exp: '2030-11-15', markup: '40%', date: '2025-05-27', discount: '8%', priceDiscount: '44620 ₸', mult: '1' },
                    { supplier: 'ТОО "ДентИмплант Плюс"', city: 'Шымкент', price: '46800 ₸', stock: 22, exp: '2030-10-30', markup: '38%', date: '2025-05-29', discount: '3%', priceDiscount: '45396 ₸', mult: '1' }
                ];
            } else if (productId === '8') { // Импланты Straumann
                sampleData = [
                    { supplier: 'ТОО "Премиум Дент"', city: 'Алматы', price: '85000 ₸', stock: 15, exp: '2032-12-31', markup: '45%', date: '2025-05-28', discount: '10%', priceDiscount: '76500 ₸', mult: '1' },
                    { supplier: 'ТОО "Швейцария Дент КЗ"', city: 'Астана', price: '82000 ₸', stock: 12, exp: '2032-11-20', markup: '42%', date: '2025-05-27', discount: '7%', priceDiscount: '76260 ₸', mult: '1' },
                    { supplier: 'ТОО "Элит Имплант"', city: 'Караганда', price: '88500 ₸', stock: 10, exp: '2032-10-15', markup: '48%', date: '2025-05-29', discount: '12%', priceDiscount: '77880 ₸', mult: '1' }
                ];
            }

            sampleData.forEach(function (item) {
                var tr = document.createElement('tr');
                // Поставщик с кликом
                var tdSup = document.createElement('td');
                tdSup.textContent = item.supplier;
                tdSup.style.cursor = 'pointer';
                tdSup.addEventListener('click', function () {
                    document.getElementById('modalSupplier').value = item.supplier;
                    document.getElementById('modalStock').value = item.stock;
                    document.getElementById('modalExp').value = item.exp;
                    document.getElementById('modalPrice').value = item.price;
                    document.getElementById('modalDiscount').value = item.discount;
                    document.getElementById('modalPriceDiscount').value = item.priceDiscount;
                    document.getElementById('modalMult').value = item.mult;
                    document.getElementById('modalQuantity').value = 1;

                    // Сохраняем данные для добавления в заказ
                    currentProductData.supplier = item.supplier;
                    currentProductData.city = item.city;
                    currentProductData.price = item.price;
                    currentProductData.priceDiscount = item.priceDiscount;
                    currentProductData.exp = item.exp;
                    currentProductData.stock = item.stock;
                    currentProductData.mult = item.mult;
                    currentProductData.discount = item.discount;
                    currentProductData.priceDiscount = item.priceDiscount;
                    new bootstrap.Modal(document.getElementById('supplierModal')).show();
                });
                tr.appendChild(tdSup);
                ['city', 'price', 'stock', 'discount', 'priceDiscount'].forEach(function (key) {
                    var td = document.createElement('td');
                    td.textContent = item[key];
                    tr.appendChild(td);
                });
                tbody.appendChild(tr);
            });
        }

        function addToOrder() {
            const quantity = parseInt(document.getElementById('modalQuantity').value) || 1;
            const priceText = currentProductData.priceDiscount || currentProductData.price;
            const price = parseFloat(priceText.replace(/[^\d]/g, ''));

            const orderItem = {
                id: Date.now(),
                productId: currentProductData.productId,
                productName: currentProductData.productName,
                supplier: currentProductData.supplier,
                city: currentProductData.city,
                price: price,
                priceText: priceText,
                quantity: quantity,
                total: price * quantity,
                exp: currentProductData.exp,
                stock: currentProductData.stock,
                discount : currentProductData.discount,

                dateAdded: new Date().toLocaleString('ru-RU')
            };

            activeOrders.push(orderItem);
            updateOrdersDisplay();

            bootstrap.Modal.getInstance(document.getElementById('supplierModal')).hide();
            showNotification('Товар добавлен в заказ!', 'success');
        }

        function updateOrdersDisplay() {
            const container = document.getElementById('supplierOrderGroups');
            const emptyMessage = document.getElementById('emptyOrdersMessage');
            const tableContainer = document.getElementById('ordersTableContainer');
            const orderActions = document.getElementById('orderActions');

            container.innerHTML = '';

            if (activeOrders.length === 0) {
                emptyMessage.style.display = 'block';
                tableContainer.style.display = 'none';
                orderActions.style.display = 'none';
            } else {
                emptyMessage.style.display = 'none';
                tableContainer.style.display = 'block';
                orderActions.style.display = 'flex';

                const groupedOrders = activeOrders.reduce((groups, order) => {
                    const supplier = order.supplier;
                    if (!groups[supplier]) {
                        groups[supplier] = [];
                    }
                    groups[supplier].push(order);
                    return groups;
                }, {});

                Object.keys(groupedOrders).forEach(supplier => {
                    const supplierOrders = groupedOrders[supplier];
                    const supplierTotal = supplierOrders.reduce((sum, order) => sum + order.total, 0);
                    const supplierItemCount = supplierOrders.reduce((sum, order) => sum + order.quantity, 0);

                    const supplierBlock = document.createElement('div');
                    supplierBlock.className = 'card mb-3';
                    supplierBlock.innerHTML = `
                                    <div class="card border-0 shadow-sm mb-4">
          <!-- 🔹 Заголовок поставщика -->
          <div class="card-header bg-light py-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
              <h6 class="mb-2 mb-md-0 fw-bold text-primary d-flex align-items-center gap-2">
                <i class="bi bi-building"></i> ${supplier}
              </h6>
              <div class="d-flex align-items-center gap-2">
                <span class="badge bg-primary-subtle text-primary px-3 py-2 shadow-sm">
                  ${supplierItemCount} шт.
                </span>
                <span class="badge bg-success-subtle text-success px-3 py-2 shadow-sm">
                  ${supplierTotal.toLocaleString()} ₸
                </span>
                <button class="btn btn-outline-danger btn-sm rounded-circle shadow-sm"
                        title="Удалить все заказы поставщика"
                        onclick="removeSupplierOrders('${supplier}')">
                  <i class="bi bi-trash"></i>
                </button>
              </div>
            </div>
          </div>

          <!-- 🔹 Таблица товаров -->
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr class="text-secondary small">
                    <th>Товар</th>
                    <th class="text-center">Цена за ед.</th>
                    <th class="text-center">Количество</th>
                    <th class="text-center">Скидка</th>
                    <th class="text-center">Сумма</th>
                    <th class="text-center">Дата добавления</th>
                    <th class="text-center"></th>
                  </tr>
                </thead>
                <tbody>
                  ${supplierOrders.map(order => `
                    <tr>
                      <td>
                        <div class="fw-semibold">${order.productName}</div>
                        <small class="text-muted">${order.city}</small>
                      </td>
                      <td class="text-center">${order.priceText}</td>
                      <td class="text-center">
                        <div class="input-group input-group-sm mx-auto" style="width: 130px;">
                          <button class="btn btn-outline-secondary" type="button" onclick="changeQuantity(${order.id}, -1)">
                            <i class="bi bi-dash"></i>
                          </button>
                          <input type="text" class="form-control text-center fw-semibold" value="${order.quantity}" readonly>
                          <button class="btn btn-outline-secondary" type="button" onclick="changeQuantity(${order.id}, 1)">
                            <i class="bi bi-plus"></i>
                          </button>
                        </div>
                      </td>
                                       <td class="text-center">
                                <small class="text-muted">${order.discount}</small>
                              </td>
                      <td class="text-center fw-bold text-success">${order.total.toLocaleString()} ₸</td>
                      <td class="text-center">
                        <small class="text-muted">${order.dateAdded}</small>
                      </td>
                      <td class="text-center">
                        <button class="btn btn-outline-danger btn-sm rounded-circle shadow-sm"
                                title="Удалить товар"
                                onclick="removeFromOrder(${order.id})">
                          <i class="bi bi-trash"></i>
                        </button>
                      </td>
                    </tr>
                  `).join('')}
                </tbody>
              </table>
            </div>
          </div>

          <!-- 🔹 Нижняя панель с кнопками -->
          <div class="card-footer bg-white border-top-0 d-flex justify-content-end gap-2 py-3">
            <button class="btn btn-outline-primary d-flex align-items-center gap-2 shadow-sm">
              <i class="bi bi-download"></i> Экспорт
            </button>
            <button class="btn btn-primary d-flex align-items-center gap-2 shadow-sm">
              <i class="bi bi-check2-circle"></i> Оформить заказ
            </button>
          </div>
        </div>
                          `;
                    container.appendChild(supplierBlock);
                });
            }

            updateOrderSummary();
        }

        function updateOrderSummary() {
            const totalItems = activeOrders.reduce((sum, order) => sum + order.quantity, 0);
            const totalAmount = activeOrders.reduce((sum, order) => sum + order.total, 0);

            document.getElementById('orderCount').textContent = `${totalItems} товаров`;
            document.getElementById('totalAmount').textContent = `${totalAmount.toLocaleString()} ₸`;
            document.getElementById('summaryCount').textContent = totalItems;
            document.getElementById('summaryTotal').textContent = `${totalAmount.toLocaleString()} ₸`;
        }

        function changeQuantity(orderId, change) {
            const order = activeOrders.find(o => o.id === orderId);
            if (order) {
                const newQuantity = order.quantity + change;
                if (newQuantity > 0 && newQuantity <= order.stock) {
                    order.quantity = newQuantity;
                    order.total = order.price * order.quantity;
                    updateOrdersDisplay();
                }
            }
        }

        function removeFromOrder(orderId) {
            activeOrders = activeOrders.filter(o => o.id !== orderId);
            updateOrdersDisplay();
            showNotification('Товар удален из заказа', 'warning');
        }

        function removeSupplierOrders(supplier) {
            if (confirm(`Удалить все товары от поставщика "${supplier}"?`)) {
                activeOrders = activeOrders.filter(o => o.supplier !== supplier);
                updateOrdersDisplay();
                showNotification(`Все товары от поставщика "${supplier}" удалены`, 'warning');
            }
        }

        function changeModalQuantity(change) {
            const input = document.getElementById('modalQuantity');
            const newValue = parseInt(input.value) + change;
            if (newValue >= 1) {
                input.value = newValue;
            }
        }

        function showNotification(message, type = 'info') {
            const alertClass = type === 'success' ? 'alert-success' :
                type === 'warning' ? 'alert-warning' : 'alert-info';

            const alert = document.createElement('div');
            alert.className = `alert ${alertClass} alert-dismissible fade show position-fixed`;
            alert.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
            alert.innerHTML = `
                        ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                      `;

            document.body.appendChild(alert);

            setTimeout(() => {
                if (alert.parentNode) {
                    alert.parentNode.removeChild(alert);
                }
            }, 3000);
        }

        function filterProducts() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const categoryFilter = document.getElementById('categoryFilter').value;
            const brandFilter = document.getElementById('brandFilter').value;
            const countryFilter = document.getElementById('countryFilter').value;
            const materialFilter = document.getElementById('materialFilter').value;

            const productRows = document.querySelectorAll('.product-row');

            productRows.forEach(function (row) {
                const productName = row.dataset.productName.toLowerCase();
                const category = row.dataset.category || '';
                const brand = row.dataset.brand || '';
                const country = row.dataset.country || '';
                const material = row.dataset.material || '';
                const nextRow = row.nextElementSibling;

                let shouldShow = true;

                if (searchTerm && !productName.includes(searchTerm)) {
                    shouldShow = false;
                }

                if (categoryFilter && category !== categoryFilter) shouldShow = false;
                if (brandFilter && brand !== brandFilter) shouldShow = false;
                if (countryFilter && country !== countryFilter) shouldShow = false;
                if (materialFilter && material !== materialFilter) shouldShow = false;

                if (shouldShow) {
                    row.style.display = '';
                    if (nextRow && nextRow.classList.contains('collapse')) {
                        nextRow.style.display = '';
                    }
                } else {
                    row.style.display = 'none';
                    if (nextRow && nextRow.classList.contains('collapse')) {
                        nextRow.style.display = 'none';
                    }
                }
            });
        }
    </script>
</body>
</html>